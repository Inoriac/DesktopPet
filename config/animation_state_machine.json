{
  "defaultState": "Intro",

  "states": [
    { "name": "Intro", "loop": true, "clipOptions": [] },
    { "name": "Idle", "loop": true, "clipOptions": [] },
    { "name": "Dance", "loop": true, "clipOptions": [] },
    { "name": "Sitting", "loop": true, "clipOptions": [] },
    { "name": "Sleeping", "loop": true, "clipOptions": [] }
  ],

  "transactions": [
    { "fromState": "Intro", "toState": "Idle", "condition": "", "blendDuration": 0.3 },

    { "fromState": "Idle", "toState": "Dance", "condition": "start_dance" },
    { "fromState": "Idle", "toState": "Sitting", "condition": "sit" },
    { "fromState": "Idle", "toState": "Sleeping", "condition": "sleep" },

    { "fromState": "Sitting", "toState": "Idle", "condition": "stand" },
    { "fromState": "Sitting", "toState": "Sleeping", "condition": "sleep" },

    { "fromState": "Sleeping", "toState": "Idle", "condition": "wake" },

    { "fromState": "Dance", "toState": "Idle", "condition": "stop_dance" }
  ]
}
